{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/data/**",
              "components/forms/**",
              "components/layout/**",
              "ui_kits/risk-dashboard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Roboto|Roboto Mono|Inter))/i]",
        "message": "Font not provided by the design system. Available: Roboto, Roboto Mono, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavGroup'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|items|key|ref|className|style|children)$/]",
        "message": "<NavGroup> doesn't accept that prop. Declared props: label, items."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:lime|green|neutral|positive|negative)$/]",
        "message": "<Badge> tone must be one of 'lime' | 'green' | 'neutral' | 'positive' | 'negative'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|go|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'go' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DashboardCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|titleVariant|avatar|icon|actions|children|padded|style|key|ref|className|style|children)$/]",
        "message": "<DashboardCard> doesn't accept that prop. Declared props: title, titleVariant, avatar, icon, actions, children, padded, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DashboardCard'] > JSXAttribute[name.name='titleVariant'] > Literal[value!=/^(?:card|section)$/]",
        "message": "<DashboardCard> titleVariant must be one of 'card' | 'section'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DashboardCard'] > JSXAttribute[name.name='avatar'] > Literal[value!=/^(?:entity|products|risk)$/]",
        "message": "<DashboardCard> avatar must be one of 'entity' | 'products' | 'risk'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|header|numeric|align|width|render|key|ref|className|style|children)$/]",
        "message": "<DataColumn> doesn't accept that prop. Declared props: key, header, numeric, align, width, render."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<DataColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterSelect'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|options|onChange|placeholder|width|style|key|ref|className|style|children)$/]",
        "message": "<FilterSelect> doesn't accept that prop. Declared props: label, value, options, onChange, placeholder, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GradientDivider'] > JSXAttribute > JSXIdentifier[name!=/^(?:orientation|length|style|key|ref|className|style|children)$/]",
        "message": "<GradientDivider> doesn't accept that prop. Declared props: orientation, length, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GradientDivider'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:horizontal|vertical)$/]",
        "message": "<GradientDivider> orientation must be one of 'horizontal' | 'vertical'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCell'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|change|direction|style|key|ref|className|style|children)$/]",
        "message": "<MetricCell> doesn't accept that prop. Declared props: label, value, unit, change, direction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCell'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:positive|negative)$/]",
        "message": "<MetricCell> direction must be one of 'positive' | 'negative'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label, icon."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
